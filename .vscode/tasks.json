{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-plugin",
            "type": "shell",
            "command": "mvn clean package",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "reload-plugin",
            "type": "shell",
            "command": "mcrcon -H 127.0.0.1 -P 25575 -p pass123 'plugman reload all'",
            "dependsOn": "build-plugin",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}