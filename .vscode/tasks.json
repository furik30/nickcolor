{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-plugin",
            "type": "shell",
            "command": "mvn clean package",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "start-server",
            "type": "shell",
            "isBackground": true,
            "command": "java -Xms1G -Xmx2G -agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5005 -Dcom.mojang.eula.agree=true -jar server.jar nogui",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "dependsOn": "build-plugin",
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "\\b\\B",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^",
                        "endsPattern": "Listening for transport dt_socket"
                    }
                }
            ]
        }
    ]
}